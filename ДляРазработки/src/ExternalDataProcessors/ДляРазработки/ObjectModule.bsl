// Генерировать тестовые данные.
// 
// Параметры:
//  Сообщать - Булево - Сообщать
Процедура ГенерироватьТестовыеДанные(Сообщать = Истина) Экспорт

	//	Справочники
	ГенерироватьКлиентов(Сообщать);
	ГенерироватьВидыКухни(Сообщать);
	ГенерироватьНоменклатуру(Сообщать);
	ГенерироватьКурьеров(Сообщать);
	ГенерироватьВелосипеды(Сообщать);
	//	Документы
	ГенерироватьЦены(Сообщать);
	ГенерироватьШкалыБонусов(Сообщать);
	ГенерироватьЗаказы(Сообщать);
	ГенерироватьОплатыЗаказов(Сообщать);

КонецПроцедуры

// Очистить тестовые данные.
// 
// Параметры:
//  Сообщать - Булево - Сообщать
Процедура ОчиститьТестовыеДанные(Сообщать = Истина) Экспорт
	
	//	Справочники
	ОчиститьКлиентов(Сообщать);
	ОчиститьВидыКухни(Сообщать);
	ОчиститьНоменклатуру(Сообщать);
	ОчиститьКурьеров(Сообщать);
	ОчиститьВелосипеды(Сообщать);
	//	Документы
	ОчиститьЦены(Сообщать);
	ОчиститьШкалыБонусов(Сообщать);
	ОчиститьЗаказы(Сообщать);
	ОчиститьОплатыЗаказов(Сообщать);
	
КонецПроцедуры

// Генерировать клиентов.
// 
// Параметры:
//  Сообщать - Булево - Сообщать
Процедура ГенерироватьКлиентов(Сообщать = Ложь) Экспорт
	
	ОчиститьКлиентов();
	
	ТеннисистыТекст = ПолучитьМакет("Теннисисты").ПолучитьТекст();
	МассивКлиентов = СтрРазделить(ТеннисистыТекст, Символы.ПС);
	КоличествоКлиентов = МассивКлиентов.Количество();
	ТелефоныТекст = ПолучитьМакет("Телефоны").ПолучитьТекст();
	МассивТелефонов = СтрРазделить(ТелефоныТекст, Символы.ПС);
	КоличествоТелефонов = МассивТелефонов.Количество();
	АдресаТекст = ПолучитьМакет("Адреса").ПолучитьТекст();
	МассивАдресов = СтрРазделить(АдресаТекст, Символы.ПС);
	КоличествоАдресов = МассивАдресов.Количество();
	ДопустимыеКоды = ОбщиеФункцииКлиентСервер.ПолучитьДопустимыеКоды();
	МассивКодов = Новый Массив; // Массив из Строка
	
	Для Каждого СвойствоКод Из ДопустимыеКоды Цикл
		
		Код = СвойствоКод.Значение; // Строка
		МассивКодов.Добавить(Код);
		
	КонецЦикла;
	
	КоличествоЗаписейКлиентов = Мин(КоличествоКлиентов, КоличествоТелефонов, КоличествоАдресов);
	ГСЧ = Новый ГенераторСлучайныхЧисел();

	Для Индекс = 1 По КоличествоЗаписейКлиентов Цикл
		
		ИндексМассива = Индекс - 1;
		ИндексМассиваКода = ГСЧ.СлучайноеЧисло(0, МассивКодов.Количество() - 1);
		
		Клиент = Справочники.Клиенты.СоздатьЭлемент();
		Клиент.Наименование = МассивКлиентов[ИндексМассива];
		Клиент.Телефон = МассивКодов[ИндексМассиваКода] + МассивТелефонов[ИндексМассива];
		Клиент.Адрес = МассивАдресов[ИндексМассива];
		Клиент.Записать();
		
	КонецЦикла;
	
	Если Сообщать Тогда	
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Сгенерировано клиентов: " + КоличествоЗаписейКлиентов;
		Сообщение.Сообщить();
		
	КонецЕсли;

КонецПроцедуры

// Очистить клиентов.
// 
// Параметры:
//  Сообщать - Булево - Сообщать
Процедура ОчиститьКлиентов(Сообщать = Ложь) Экспорт
	
	Выборка = Справочники.Клиенты.Выбрать();
	КоличествоЗаписейКлиентов = 0;
	
	Пока Выборка.Следующий() Цикл

		Объект = Выборка.ПолучитьОбъект();
		Объект.ОбменДанными.Загрузка = Истина; 
		Объект.Удалить();
		
		КоличествоЗаписейКлиентов = КоличествоЗаписейКлиентов + 1;

	КонецЦикла;
	
	Если Сообщать Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Очищено клиентов: " + КоличествоЗаписейКлиентов;
		Сообщение.Сообщить();
		
	КонецЕсли;
	
КонецПроцедуры

