	КонецЦикла;
	
	Если Сообщать Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Очищено номенклатуры: " + КоличествоНоменклатуры;
		Сообщение.Сообщить();
		
	КонецЕсли;
	
КонецПроцедуры

