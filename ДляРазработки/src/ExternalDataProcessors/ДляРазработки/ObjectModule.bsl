// Генерировать велосипеды.
// 
// Параметры:
//  Сообщать - Булево - Сообщать
Процедура ГенерироватьВелосипеды(Сообщать = Ложь) Экспорт
	
	ОчиститьВелосипеды();
	
	ВелосипедыТекст = ПолучитьМакет("Велосипеды").ПолучитьТекст();
	МассивНазванийВелосипедов = СтрРазделить(ВелосипедыТекст, Символы.ПС);
	КоличествоНазванийВелосипедов = МассивНазванийВелосипедов.Количество();
	СерийныеНомераТекст = ПолучитьМакет("СерийныеНомераВелосипедов").ПолучитьТекст();
	МассивСерийныхНомеров = СтрРазделить(СерийныеНомераТекст, Символы.ПС);
	КоличествоСерийныхНомеров = МассивСерийныхНомеров.Количество();
	
	ГСЧ = Новый ГенераторСлучайныхЧисел();

	Для Индекс = 1 По КоличествоСерийныхНомеров Цикл
		
		ИндексМассива = Индекс - 1;
		ИндексМассиваНазванийВелосипедов = ГСЧ.СлучайноеЧисло(0, КоличествоНазванийВелосипедов - 1);
		
		Велосипед = Справочники.Велосипеды.СоздатьЭлемент();
		Велосипед.Наименование = МассивНазванийВелосипедов[ИндексМассиваНазванийВелосипедов];
		Велосипед.СерийныйНомер = МассивСерийныхНомеров[ИндексМассива];
		Велосипед.Записать();
		
	КонецЦикла;

	Если Сообщать Тогда	
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Сгенерировано велосипедов: " + КоличествоСерийныхНомеров;
		Сообщение.Сообщить();
		
	КонецЕсли;

КонецПроцедуры

