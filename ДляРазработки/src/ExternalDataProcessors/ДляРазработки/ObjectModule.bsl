        Если Объект.Проведен Тогда
            Объект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
        КонецЕсли;		

		Объект.ОбменДанными.Загрузка = Истина; 
		Объект.Удалить();
		
		КоличествоОплатЗаказов = КоличествоОплатЗаказов + 1;

	КонецЦикла;

	Если Сообщать Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Очищено оплат заказов: " + КоличествоОплатЗаказов;
		Сообщение.Сообщить();
		
	КонецЕсли;
	
КонецПроцедуры

