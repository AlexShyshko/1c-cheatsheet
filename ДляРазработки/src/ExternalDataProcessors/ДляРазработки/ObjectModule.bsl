// Генерировать номенклатуру.
// 
// Параметры:
//  Сообщать - Булево - Сообщать
Процедура ГенерироватьНоменклатуру(Сообщать = Ложь) Экспорт
	
	ОчиститьНоменклатуру();
	
	ТоварыГруппа = Справочники.Номенклатура.СоздатьГруппу();
	ТоварыГруппа.Наименование = "Товары";
	ТоварыГруппа.Записать();
	
	ТоварыМакет = ПолучитьМакет("Товары");
	КоличествоТоваров = ТоварыМакет.ВысотаТаблицы;
	
	Для НомерСтроки = 1 По КоличествоТоваров Цикл
		
		НазваниеТовара = ТоварыМакет.Область(НомерСтроки, 1).Текст;
		НазваниеКухни = ТоварыМакет.Область(НомерСтроки, 2).Текст;
		ВидКухни = Справочники.ВидыКухни.НайтиПоНаименованию(НазваниеКухни);
		
		Товар = Справочники.Номенклатура.СоздатьЭлемент();
		Товар.Родитель = ТоварыГруппа.Ссылка;
		Товар.Наименование = НазваниеТовара;
		Товар.ВидНоменклатуры = Перечисления.ВидНоменклатуры.Товар;
		Товар.ВидКухни = ВидКухни;
		Товар.Записать();
		
	КонецЦикла;
	
	УслугиГруппа = Справочники.Номенклатура.СоздатьГруппу();
	УслугиГруппа.Наименование = "Услуги";
	УслугиГруппа.Записать();
	
	УслугиТекст = ПолучитьМакет("Услуги").ПолучитьТекст();
	МассивУслуг = СтрРазделить(УслугиТекст, Символы.ПС);
	КоличествоУслуг = МассивУслуг.Количество();
	
	Для Индекс = 1 По КоличествоУслуг Цикл
		
		ИндексМассива = Индекс - 1;
		
		Услуга = Справочники.Номенклатура.СоздатьЭлемент();
		Услуга.Родитель = УслугиГруппа.Ссылка;
		Услуга.Наименование = МассивУслуг[ИндексМассива];
		Услуга.ВидНоменклатуры = Перечисления.ВидНоменклатуры.Услуга;
		Услуга.Записать();
		
	КонецЦикла;
	
	КоличествоНоменклатуры = КоличествоТоваров + КоличествоУслуг;
	
	Если Сообщать Тогда	
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Сгенерировано номенклатуры: " + КоличествоНоменклатуры;
		Сообщение.Сообщить();
	
	КонецЕсли;
	
КонецПроцедуры

// Очистить номенклатуру.
// 
// Параметры:
//  Сообщать - Булево - Сообщать
Процедура ОчиститьНоменклатуру(Сообщать = Ложь) Экспорт
	
	Выборка = Справочники.Номенклатура.Выбрать();
