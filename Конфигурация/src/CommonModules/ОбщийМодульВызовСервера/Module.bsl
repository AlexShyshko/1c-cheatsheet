// @strict-types

#Область ПрограммныйИнтерфейс

// Получить цену и вид номенклатуры.
// 
// Параметры:
//  Период - Дата
//  Номенклатура - СправочникСсылка.Номенклатура - справочник "Номенклатура"
// 
// Возвращаемое значение:
//  Структура - Получить цену и вид номенклатуры:
// * ИмяВидаНоменклатуры - Строка
// * Цена - Число
Функция ПолучитьЦенуИВидНоменклатуры(Период, Номенклатура) Экспорт
	
	ВидНоменклатуры = ПолучитьВидНоменклатуры(Номенклатура);
	ИндексНоменклатуры = Перечисления.ВидНоменклатуры.Индекс(ВидНоменклатуры);
	ИмяВидаНоменклатуры = Метаданные.Перечисления.ВидНоменклатуры.ЗначенияПеречисления[ИндексНоменклатуры].Имя;
	ЦенаНоменклатуры = ПолучитьЦенуНоменклатуры(Период, Номенклатура);
	Результат = Новый Структура("ИмяВидаНоменклатуры, Цена", ИмяВидаНоменклатуры, ЦенаНоменклатуры);

	Возврат Результат;
	
КонецФункции

// Получить текущую дату.
// 
// Возвращаемое значение:
//  Дата - Получить текущую дату
Функция ПолучитьТекущуюДату() Экспорт
	Возврат ТекущаяДатаСеанса();
КонецФункции

// Получить информацию о клиенте.
// 
// Параметры:
//  ОбъектСсылка - ДокументСсылка.Заказ
//  ДатаЗаказа - Дата
//  Клиент - СправочникСсылка.Клиенты
//  Цена - Число - Цена для проверяемого заказа до скидки
// 
// Возвращаемое значение:
//  Структура - Получить информацию о клиенте:
// * ЗначениеЗаполнено - Булево
// * СуммаБалловОстаток - Число
// * ПроцентНакопления - Число
// * БаллыКНакоплению - Число
// * Адрес - Строка
Функция ПолучитьИнформациюОКлиенте(ОбъектСсылка, ДатаЗаказа, Клиент, Цена) Экспорт
	
	Перем МоментВремениЗаказа; // МоментВремени
	
	Ответ = Новый Структура;
	Ответ.Вставить("ЗначениеЗаполнено", Истина);
	Ответ.Вставить("СуммаБалловОстаток", 0);
	Ответ.Вставить("ПроцентНакопления", 0);
	Ответ.Вставить("БаллыКНакоплению", 0);
	Ответ.Вставить("Адрес", "");
	
	Если Не ЗначениеЗаполнено(ОбъектСсылка) Тогда

		// Обработка
		Если Не ЗначениеЗаполнено(ДатаЗаказа) Тогда
			ДатаЗаказа = ПолучитьТекущуюДату();
		КонецЕсли;
		
		// Новый документ
		МоментВремениЗаказа = Новый МоментВремени(ДатаЗаказа);

	Иначе
		
		// Записанный документ
		МоментВремениЗаказа = ОбъектСсылка.МоментВремени();
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Клиент) Тогда
		
		Ответ.ЗначениеЗаполнено = Ложь;
		Возврат Ответ;
		
	КонецЕсли;

		Ответ.СуммаБалловОстаток = ПолучитьСуммуБаллов(МоментВремениЗаказа, Клиент);

		СуммаПокупок = ПолучитьСуммуПокупок(Новый Граница(МоментВремениЗаказа, ВидГраницы.Исключая), Клиент);
		ПроцентНакопления = ПолучитьПроцентНакопления(
			НачалоДня(ДатаЗаказа),
			СуммаПокупок
		);

		Ответ.ПроцентНакопления = ПроцентНакопления;
		
		БаллыКНакоплению = ПолучитьБаллыКНакоплениюЧерезПроцент(
			ПроцентНакопления,
			Цена
		);
		
		Ответ.БаллыКНакоплению = БаллыКНакоплению;
		Ответ.Адрес = ВернутьАдресКлиента(Клиент);

	Возврат Ответ;
	
КонецФункции

// Вернуть адрес клиента.
// 
// Параметры:
//  Клиент - СправочникСсылка.Клиенты
// 
// Возвращаемое значение:
//  Строка - Вернуть адрес клиента
Функция ВернутьАдресКлиента(Клиент) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Клиенты.Адрес КАК Адрес
		|ИЗ
		|	Справочник.Клиенты КАК Клиенты
		|ГДЕ
		|	Клиенты.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Клиент);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Адрес;
	КонецЕсли;
	
КонецФункции

// Получить отрицательную сумму баллов на период.
// 
// Параметры:
//  Период - Дата
//  Клиент - СправочникСсылка.Клиенты
// 
// Возвращаемое значение:
//  Число - Возвращает Число или Неопределено, если данных нет
Функция ПолучитьОтрицательнуюСуммуБалловНаПериод(Период, Клиент) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	БонусныеБаллыКлиентовОстатки.СуммаБалловОстаток КАК СуммаБалловОстаток
		|ИЗ
		|	РегистрНакопления.БонусныеБаллыКлиентов.Остатки(&Период, Клиент = &Клиент) КАК БонусныеБаллыКлиентовОстатки
		|ГДЕ
		|	БонусныеБаллыКлиентовОстатки.СуммаБалловОстаток < 0";
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Клиент", Клиент);
		
	Выборка = Запрос.Выполнить().Выбрать();

	Если Выборка.Следующий() Тогда
		
		Возврат Выборка.СуммаБалловОстаток;
		
	Иначе
		
		Возврат Неопределено;
		
	КонецЕсли
	
КонецФункции

// Получить баллы к накоплению, передавая параметром клиента.
// 
// Параметры:
//  ВремяДоЗаказа - Дата - Время до заказа
//  Клиент - СправочникСсылка.Клиенты - Клиент
//  ДатаЗаказа - Дата - Дата заказа
//  ЦенаЗаказа - Число - Цена заказа
// 
// Возвращаемое значение:
//  Число - Баллы к накоплению
Функция ПолучитьБаллыКНакоплениюЧерезКлиента(ВремяДоЗаказа, Клиент, ДатаЗаказа, ЦенаЗаказа) Экспорт
	
	СуммаПокупок = ПолучитьСуммуПокупок(ВремяДоЗаказа, Клиент);
	ПроцентНакопления = ПолучитьПроцентНакопления(ДатаЗаказа, СуммаПокупок);
	БаллыКНакоплению = ЦенаЗаказа * ПроцентНакопления / 100;
	БаллыКНакоплениюДваЗнака = ОбщиеФункцииКлиентСервер.ОбрезатьДробнуюЧастьДоДвухЗнаков(БаллыКНакоплению);
	
	Возврат БаллыКНакоплениюДваЗнака;
	
КонецФункции

// Получить баллы к накоплению, передавая параметром ранее рассчитанный ПроцентНакопления.
// 
// Параметры:
//  ПроцентНакопления - Число
//  ЦенаЗаказа - Число
// 
// Возвращаемое значение:
//  Число - Баллы к накоплению
Функция ПолучитьБаллыКНакоплениюЧерезПроцент(ПроцентНакопления, ЦенаЗаказа) Экспорт

	БаллыКНакоплению = ЦенаЗаказа * ПроцентНакопления / 100;
	БаллыКНакоплениюДваЗнака = ОбщиеФункцииКлиентСервер.ОбрезатьДробнуюЧастьДоДвухЗнаков(БаллыКНакоплению);
	
	Возврат БаллыКНакоплениюДваЗнака;
	
КонецФункции

// Заполнить наиболее часто заказываемые товары.
//
// Параметры:
//  ОбъектДляЗаполнения - ФормаКлиентскогоПриложения
//  КоллекцияИзбранныхТоваров - ДанныеФормыКоллекция из ДанныеФормыЭлементКоллекции:
//   * Активность - Булево
//   * Номенклатура - СправочникСсылка.Номенклатура
//   * Цена - Число
//  Клиент - СправочникСсылка.Клиенты
Процедура ЗаполнитьИзбранныеТовары(ОбъектДляЗаполнения, КоллекцияИзбранныхТоваров, Клиент) Экспорт

	СброситьИзбранныеТовары(КоллекцияИзбранныхТоваров);
	
	Если ЗначениеЗаполнено(Клиент) Тогда

		НачалоПериода = ДобавитьМесяц(ТекущаяДатаСеанса(), -3);
		КонецПериода = ТекущаяДатаСеанса();
		ИзбранныеТоварыВыборка = ПолучитьИзбранныеТовары(НачалоПериода, КонецПериода, Клиент);
		
		Счётчик = 0;
		
		Пока ИзбранныеТоварыВыборка.Следующий() Цикл

			ТекущаяСтрокаКоллекции = КоллекцияИзбранныхТоваров[Счётчик];
			ТекущаяСтрокаКоллекции.Активность = Истина;
			ТекущаяСтрокаКоллекции.Номенклатура = ИзбранныеТоварыВыборка.Товар;
			ТекущаяСтрокаКоллекции.Цена = ИзбранныеТоварыВыборка.Цена;
			
			Счётчик = Счётчик + 1;
			
		КонецЦикла;

	КонецЕсли;
	
	ЗаполнитьДекорацииИзбранныхТоваров(КоллекцияИзбранныхТоваров, ОбъектДляЗаполнения.Элементы);
	
КонецПроцедуры

// Придать начальный вид.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения:
//    * ДинамическиеЭлементы - ДанныеФормыКоллекция
//    * Клиент - СправочникСсылка.Клиенты
//  ДанныеФормы - ДанныеФормыСтруктура:
//    * Клиент - СправочникСсылка.Клиенты
//  Элементы - ВсеЭлементыФормы
Процедура ПридатьНачальныйВидФормеЗаказа(Форма, ДанныеФормы, Элементы) Экспорт

	ОбъектСВидимымиПолями = Неопределено;
	
	// Когда форма Документа
	Если ДанныеФормы.Свойство("Клиент") Тогда
		ОбъектСВидимымиПолями = ДанныеФормы;
	// Когда форма Обработки
	Иначе
		ОбъектСВидимымиПолями = Форма;
	КонецЕсли;
	
	Элементы.ДекорацияБаллыКлиента.Видимость = Ложь;

	ЗаполнитьИзбранныеТовары(Форма, Форма.ДинамическиеЭлементы, ОбъектСВидимымиПолями.Клиент);

КонецПроцедуры

// Очистить форму.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения:
//    * Клиент - СправочникСсылка.Клиенты
//    * Цена - Число
//    * БаллыНаСписание - Число
//    * СуммаЗаказа - Число
//    * ПозицииПродажи - ДанныеФормыКоллекция
//  ДанныеФормы - ДанныеФормыСтруктура
//  Элементы - ВсеЭлементыФормы
Процедура ОчиститьФорму(Форма, ДанныеФормы, Элементы) Экспорт
	
	Форма.Клиент = Справочники.Клиенты.ПустаяСсылка();
	ПридатьНачальныйВидФормеЗаказа(Форма, ДанныеФормы, Элементы);
	Форма.Цена = 0;
	Форма.БаллыНаСписание = 0;
	Форма.СуммаЗаказа = 0;
	Форма.ПозицииПродажи.Очистить();
	
КонецПроцедуры

// Создать декорации избранных товаров.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения:
//    * ДинамическиеЭлементы - ДанныеФормыКоллекция
//  Элементы - ВсеЭлементыФормы
Процедура СоздатьДекорацииИзбранныхТоваров(Форма, Элементы) Экспорт
	
	КоличествоИзбранныхТоваров = ПолучитьЧислоИзбранныхТоваров();
	
	Для Сч = 1 По КоличествоИзбранныхТоваров Цикл
		
		ИмяДекорации = "ДекорацияИзбранного_" + XMLСтрока(Сч);
		Декорация = Элементы.Добавить(
			ИмяДекорации,
			Тип("ДекорацияФормы"),
			Элементы.ГруппаПопулярныеПокупки
		);
		Декорация.Вид = ВидДекорацииФормы.Надпись;
		Декорация.Видимость = Ложь;
		Декорация.Гиперссылка = Истина;
		Декорация.УстановитьДействие("Нажатие", "Подключаемый_ДекорацияИзбранныхТоваровНажатие");

		СтрокаОписанияДекорации = ДобавитьДинамическийЭлемент(Форма);
		СтрокаОписанияДекорации.ИмяЭлемента = ИмяДекорации;
		
	КонецЦикла;
	
КонецПроцедуры

// Получить номенклатуру.
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Получить номенклатуру:
// * Ссылка - СправочникСсылка.Номенклатура
// * ВидНоменклатуры - ПеречислениеСсылка.ВидНоменклатуры
// * Наименование - Строка
Функция ПолучитьНоменклатуру() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка,
		|	Номенклатура.ВидНоменклатуры КАК ВидНоменклатуры,
		|	Номенклатура.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.ЭтоГруппа = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура.Код";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат Выборка;
	
КонецФункции

// Получить товары с ценой.
// 
// Параметры:
//  ТекущаяДата - Дата - 
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Получить товары с ценой:
// * СсылкаНаНоменклатуру - СправочникСсылка.Номенклатура
// * Цена - Число
Функция ПолучитьТоварыСЦеной(ТекущаяДата) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	НоменклатураСправочник.Ссылка КАК СсылкаНаНоменклатуру,
		|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ТекущаяДата,) КАК ЦеныНоменклатурыСрезПоследних
		|		ПРАВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСправочник
		|		ПО ЦеныНоменклатурыСрезПоследних.Номенклатура = НоменклатураСправочник.Ссылка
		|ГДЕ
		|	НоменклатураСправочник.ЭтоГруппа = ЛОЖЬ
		|	И НоменклатураСправочник.ВидНоменклатуры = &ВидНоменклатуры
		|УПОРЯДОЧИТЬ ПО
		|	НоменклатураСправочник.Код";
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата);
	Запрос.УстановитьПараметр("ВидНоменклатуры", Перечисления.ВидНоменклатуры.Товар);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат Выборка;
	
КонецФункции

// Получить структуру товара.
// 
// Параметры:
//  ВыборкаТоваровСЦеной см. ПолучитьТоварыСЦеной
// 
// Возвращаемое значение:
//  Структура - Получить структуру товара:
// * СсылкаНаНоменклатуру - СправочникСсылка.Номенклатура
// * Цена - Число
Функция ПолучитьСтруктуруТовара(ВыборкаТоваровСЦеной) Экспорт

	ТоварСтруктура = Новый Структура;
	ТоварСтруктура.Вставить("СсылкаНаНоменклатуру", ВыборкаТоваровСЦеной.СсылкаНаНоменклатуру);
	ТоварСтруктура.Вставить("Цена", ВыборкаТоваровСЦеной.Цена);
	Возврат ТоварСтруктура;
	
КонецФункции

// Генератор случайных дробных чисел.
// 
// Параметры:
//  Мин - Число
//  Макс - Число
//  ЗнаковПослеЗапятой - Число
// 
// Возвращаемое значение:
//  Число - Целое или дробное
Функция ГенераторСлучайныхДробныхЧисел(Мин, Макс, ЗнаковПослеЗапятой) Экспорт
	
	Минимум = ОбщиеФункцииКлиентСервер.ОбрезатьДробнуюЧасть(Мин, ЗнаковПослеЗапятой);
	Максимум = ОбщиеФункцииКлиентСервер.ОбрезатьДробнуюЧасть(Макс, ЗнаковПослеЗапятой);
	
    ГСЧ = Новый ГенераторСлучайныхЧисел();
    Точность = Pow(10, ЗнаковПослеЗапятой);
    Диапазон = (Максимум - Минимум) * Точность;
    СлучайноеЦелое = ГСЧ.СлучайноеЧисло(0, Диапазон);
    ДробноеВИскомомДиапазоне = Минимум + (СлучайноеЦелое / Точность);
    Возврат ДробноеВИскомомДиапазоне;

КонецФункции

// Получить дату последнего заказа.
// 
// Возвращаемое значение:
//  Дата - Получить дату последнего заказа
Функция ПолучитьДатуПоследнегоЗаказа() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	МАКСИМУМ(Заказ.Дата) КАК Дата
		|ИЗ
		|	Документ.Заказ КАК Заказ";
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Дата;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

// Получить заказы.
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Получить заказы:
// * Дата - Дата - 
// * СуммаЗаказа - Число - 
// * Курьер - СправочникСсылка.Курьеры - 
// * Ссылка - ДокументСсылка.Заказ - 
Функция ПолучитьЗаказы() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Заказ.Дата КАК Дата,
		|	Заказ.СуммаЗаказа КАК СуммаЗаказа,
		|	Заказ.Курьер КАК Курьер,
		|	Заказ.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.Заказ КАК Заказ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Заказ.Номер";
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат Выборка;
	
КонецФункции

