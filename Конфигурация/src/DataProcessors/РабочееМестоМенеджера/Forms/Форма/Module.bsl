КонецПроцедуры

&НаСервере
Функция СохранитьЗаказНаСервере()

	ДокументЗаказ = Документы.Заказ.СоздатьДокумент();
	
	ДокументЗаказ.Заполнить(Неопределено);
	
	ДокументЗаказ.Дата = ТекущаяДатаСеанса();
	ДокументЗаказ.Клиент = Клиент;
	ДокументЗаказ.Цена = Цена;
	ДокументЗаказ.БаллыНаСписание = БаллыНаСписание;
	ДокументЗаказ.СуммаЗаказа = СуммаЗаказа;
	
	ДокументЗаказ.ПозицииПродажи.Загрузить(ПозицииПродажи.Выгрузить());

	Если Не ДокументЗаказ.ПроверитьЗаполнение() Тогда
		Возврат Неопределено;
	КонецЕсли;

	ДокументЗаказ.Записать(РежимЗаписиДокумента.Проведение);
	
	Если ДокументЗаказ.Проведен Тогда

		ОбщийМодульВызовСервера.ОчиститьФорму(ЭтотОбъект, Объект, Элементы);
		Возврат ДокументЗаказ.Ссылка;
		
	Иначе
		Возврат Неопределено;
	КонецЕсли;

КонецФункции

