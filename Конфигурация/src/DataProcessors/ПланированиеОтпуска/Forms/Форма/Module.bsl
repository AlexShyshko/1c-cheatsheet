&НаСервере
Процедура СформироватьНаСервере()
	
	Если Не ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПлановыеОтпуска.Сотрудник КАК Сотрудник,
		|	ПлановыеОтпуска.ДатаНачала КАК ДатаНачала,
		|	ПлановыеОтпуска.ДатаОкончания КАК ДатаОкончания,
		|	ПлановыеОтпуска.Регистратор КАК Регистратор
		|ИЗ
		|	РегистрСведений.ПлановыеОтпуска КАК ПлановыеОтпуска
		|ГДЕ
		|	ПлановыеОтпуска.ДатаНачала < &КонецПериода
		|	И ПлановыеОтпуска.ДатаОкончания > &НачалоПериода";
		
	Запрос.УстановитьПараметр("НачалоПериода", Период.ДатаНачала);
	Запрос.УстановитьПараметр("КонецПериода", Период.ДатаОкончания);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// ДиаграммаГанта является реквизитом формы типа ДиаграммаГанта.
	ДиаграммаГанта.Очистить();
	
	СерияДиаграммы = ДиаграммаГанта.Серии.Добавить();
	СерияДиаграммы.Значение = "Отпуска";
	СерияДиаграммы.Текст = "Отпуска";
	
	УникальныеТочкиСотрудников = Новый Соответствие();
	
	Пока Выборка.Следующий() Цикл
		
		ТочкаДиаграммы = УникальныеТочкиСотрудников.Получить(Выборка.Сотрудник);
		
		Если ТочкаДиаграммы = Неопределено Тогда
			
			ТочкаДиаграммы = ДиаграммаГанта.Точки.Добавить();
			ТочкаДиаграммы.Значение = Выборка.Сотрудник;
			ТочкаДиаграммы.Текст = Строка(Выборка.Сотрудник);
			УникальныеТочкиСотрудников.Вставить(Выборка.Сотрудник, ТочкаДиаграммы);
			
		КонецЕсли;
	
		ЗначениеТочки = ДиаграммаГанта.ПолучитьЗначение(ТочкаДиаграммы, СерияДиаграммы);
		
		ИнтервалОтпуска = ЗначениеТочки.Добавить();
		ИнтервалОтпуска.Начало = Выборка.ДатаНачала;
		ИнтервалОтпуска.Конец = Выборка.ДатаОкончания;
		ИнтервалОтпуска.Расшифровка = Выборка.Регистратор;
		
	КонецЦикла;
	
	ДиаграммаГанта.АвтоОпределениеПолногоИнтервала = Ложь;
	ДиаграммаГанта.УстановитьПолныйИнтервал(Период.ДатаНачала, Период.ДатаОкончания);
	
