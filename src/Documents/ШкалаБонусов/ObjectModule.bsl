#Область ОбработчикиСобытий

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)

	ОписанияОшибок = Новый Массив; // Массив из см. ПолучитьОписаниеОшибки
	
	Если Диапазоны.Количество() = 0 Тогда
		
		Отказ = Истина;
		ОписанияОшибок.Добавить(ПолучитьОписаниеОшибки("Нужны диапазоны, братиш", "Диапазоны"));
		
	Иначе
		
		Если Диапазоны[0].НижняяГраница <> 0 Тогда
			
			Отказ = Истина;
			ОписанияОшибок.Добавить(ПолучитьОписаниеОшибки(
				"Нижняя граница первого диапазона должна быть 0",
				"Диапазоны[0].НижняяГраница"
			));
			
		КонецЕсли;
			
		Если Диапазоны[Диапазоны.Количество() - 1].ВерхняяГраница <> 0 Тогда
			
			Отказ = Истина;
			ОписанияОшибок.Добавить(ПолучитьОписаниеОшибки(
				"Верхняя граница последнего диапазона должна быть 0",
				СтрШаблон("Диапазоны[%1].ВерхняяГраница",
				XMLСтрока(Диапазоны.Количество() - 1))
			));
			
		КонецЕсли;
	
		Если НЕ ПроверитьГраницыДиапазонов(ОписанияОшибок).Результат Тогда
			
			Отказ = Истина;
			
		КонецЕсли;

	КонецЕсли;
	
	Если Отказ = Истина Тогда
		
		Для Каждого Ошибка Из ОписанияОшибок Цикл
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = Ошибка.Текст;
			Сообщение.УстановитьДанные(ЭтотОбъект);
			Сообщение.Поле = Ошибка.Поле;
			Сообщение.Сообщить();
			
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ,Режим)

	// регистр ШкалаБонусов
	Движения.ШкалаБонусов.Записывать = Истина;
	Движение = Движения.ШкалаБонусов.Добавить();
	Движение.Период = Дата;
	Движение.Шкала = Ссылка;

КонецПроцедуры

#КонецОбласти

//#Область СлужебныйПрограммныйИнтерфейс
//
//#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Получить описание ошибки.
// 
// Параметры:
//  Текст - Строка
//  Поле - Строка
// 
// Возвращаемое значение:
//  Структура:
//    * Текст - Строка
//    * Поле - Строка
Функция ПолучитьОписаниеОшибки(Текст, Поле)
	Возврат Новый Структура("Текст, Поле", Текст, Поле);
КонецФункции

// Проверить границы диапазонов.
// 
// Параметры:
//  ОписанияОшибок - Массив из см. ПолучитьОписаниеОшибки
// Возвращаемое значение:
//  Структура - Проверить границы диапазонов:
// * Результат - Булево
// * ОписанияОшибок - Массив из см. ПолучитьОписаниеОшибки
Функция ПроверитьГраницыДиапазонов(ОписанияОшибок)

	Перем СледующийДиапазон; // ДокументТабличнаяЧастьСтрока.ШкалаБонусов.Диапазоны

	Результат = Новый Структура("Результат, ОписанияОшибок", Истина, ОписанияОшибок);
	ПоследнийДиапазонНомер = Диапазоны.Количество() - 1;
	
	Для Сч = 0 По ПоследнийДиапазонНомер Цикл
		
		ЭтотДиапазон = Диапазоны[Сч];		
		
		Если ЭтотДиапазон.НижняяГраница >= ЭтотДиапазон.ВерхняяГраница Тогда
			
			Если Не Сч = ПоследнийДиапазонНомер Тогда

				Результат.Результат = Ложь;
				Текст = "Нижняя граница каждого диапазона (кроме последнего) должна быть меньше верхней границы";
				Поле = СтрШаблон("Диапазоны[%1].НижняяГраница", XMLСтрока(Сч));
				Ошибка = ПолучитьОписаниеОшибки(Текст, Поле);
				Результат.ОписанияОшибок.Добавить(Ошибка);

			КонецЕсли;
			
		КонецЕсли;
		
		Если Не Сч = ПоследнийДиапазонНомер Тогда
			
			СледующийДиапазон = Диапазоны[Сч + 1];
			
			Если ЭтотДиапазон.ВерхняяГраница <> СледующийДиапазон.НижняяГраница Тогда
				
				Результат.Результат = Ложь;
				Текст = "Верхняя граница каждого диапазона (кроме последнего) должна равняться нижней границе следующего диапазона";
				Поле = СтрШаблон("Диапазоны[%1].ВерхняяГраница", XMLСтрока(Сч));
				Ошибка = ПолучитьОписаниеОшибки(Текст, Поле);
				Результат.ОписанияОшибок.Добавить(Ошибка);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

//#Область Инициализация
//
